{
  "manifest_version": 3,
  "name": "UniCart",
  "version": "0.2.0",
  "description": "Save Zara and Uniqlo products to your universal cart.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "UniCart"
  },
  "background": {
    "service_worker": "background.js"
  },
  "externally_connectable": {
    "matches": ["https://unicart.vercel.app/*"]
  }
}
